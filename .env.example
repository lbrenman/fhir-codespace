# FHIR R4 Codespace Configuration

# Server port
PORT=3000

# API Key authentication (leave empty to disable)
# When set, all FHIR API requests require X-Api-Key header
FHIR_API_KEY=

# Dashboard configuration
# Set to a remote FHIR server base URL to use instead of local
# Example: FHIR_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_BASE_URL=

# PostgreSQL connection (optional)
# When set, the server uses Postgres instead of in-memory JSON files
# Requires running 001-schema.sql and 003-seed-data.sql first
# Example: DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=
